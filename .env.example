# DevPilot Configuration
# Copy this file to .env and fill in your values.

# --- GitLab (required) ---
# Personal access token with api + read_repository scopes
GITLAB_TOKEN=
# Default project ID (e.g., 12345 or group/project)
GITLAB_PROJECT_ID=
# GitLab instance URL (change for self-hosted)
GITLAB_URL=https://gitlab.com

# --- Google Cloud (required) ---
# GCP project ID where Agent Builder and Cloud Run are enabled
GOOGLE_CLOUD_PROJECT=
# GCP region for deployed services
GOOGLE_CLOUD_LOCATION=us-central1

# --- Agent behavior (optional) ---
# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info
# Maximum steps in an agent plan before forcing completion
MAX_PLAN_STEPS=10
# Retry attempts for failed tool calls
RETRY_ATTEMPTS=3
# Delay between retries in milliseconds
RETRY_DELAY_MS=1000
